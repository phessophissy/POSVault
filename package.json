
{
  "name": "POSVault-tests",
  "version": "1.0.0",
  "description": "Run unit tests on this project.",
  "type": "module",
  "private": true,
  "scripts": {
    "interact": "node scripts/interact.js",
    "fund:gov": "node scripts/fund-governance.js",
    "test": "vitest run",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "build:sdk": "cd sdk && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:sdk && npm run build:frontend",
    "typecheck": "cd sdk && npm run typecheck",
    "clean": "rm -rf sdk/dist frontend/dist"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@stacks/clarinet-sdk": "^3.9.0",
    "@stacks/transactions": "^7.2.0",
    "@types/node": "^24.4.0",
    "chokidar-cli": "^3.0.0",
    "vitest": "^4.0.7",
    "vitest-environment-clarinet": "^3.0.0"
  }
}
