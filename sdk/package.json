{
  "name": "posvault-sdk",
  "version": "1.0.0",
  "description": "JavaScript/TypeScript SDK for POSVault — Treasury Vault & DAO on Stacks (Bitcoin L2)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:clean": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build:clean"
  },
  "keywords": [
    "stacks",
    "bitcoin",
    "defi",
    "dao",
    "governance",
    "vault",
    "posvault"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@stacks/connect": ">=8.0.0",
    "@stacks/network": ">=7.0.0",
    "@stacks/transactions": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@stacks/connect": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stacks/connect": "^8.2.5",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.3.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
